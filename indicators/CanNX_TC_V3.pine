// © mInvest — cải tiến V3 (đa khung + lọc hợp lưu)
//@version=5
indicator(title="CanNX - mInvest TC V3", shorttitle="CanNX TC V3", overlay=true, max_lines_count=200, max_labels_count=200)

// ============================================================
// PHẦN 1: THAM SỐ ĐẦU VÀO
// ============================================================

// --- EMA ---
ema_fast_len = input.int(21, "EMA Nhanh", group="⚙️ EMA", minval=1)
ema_slow_len = input.int(55, "EMA Chậm",  group="⚙️ EMA", minval=1)

// --- Đa khung (MTF) ---
g_htf = "🧭 Đa khung (MTF)"
use_htf_h4  = input.bool(true,  "Bắt buộc thuận trend khung trung (H4)", group=g_htf)
htf_h4      = input.timeframe("240", "Khung trung", group=g_htf)
use_daily   = input.bool(false, "Bắt buộc thuận trend khung lớn (Daily)", group=g_htf)
htf_d       = input.timeframe("D", "Khung lớn", group=g_htf)
htf_ema_len = input.int(50, "EMA xác định trend khung lớn", group=g_htf, minval=1)

// --- ADX ---
adx_len       = input.int(14, "Độ dài ADX", group="⚙️ ADX", minval=1)
adx_threshold = input.float(22, "Ngưỡng ADX", group="⚙️ ADX", minval=1)
use_di_dir    = input.bool(true, "Yêu cầu +DI/−DI thuận hướng", group="⚙️ ADX")

// --- RSI động lượng ---
g_rsi = "📈 RSI động lượng"
use_rsi      = input.bool(true, "Bật lọc RSI", group=g_rsi)
rsi_len      = input.int(14, "Độ dài RSI", group=g_rsi, minval=1)
rsi_buy_min  = input.float(45, "Mua: RSI tối thiểu", group=g_rsi)
rsi_buy_max  = input.float(70, "Mua: RSI tối đa (tránh quá mua)", group=g_rsi)
rsi_sell_max = input.float(55, "Bán: RSI tối đa", group=g_rsi)
rsi_sell_min = input.float(30, "Bán: RSI tối thiểu (tránh quá bán)", group=g_rsi)

// --- Hồi về EMA (pullback) ---
g_pb = "↩️ Hồi về EMA (pullback)"
use_pullback = input.bool(true, "Chỉ vào khi giá hồi về EMA nhanh", group=g_pb)
pullback_atr = input.float(0.6, "Khoảng cách tối đa tới EMA (xATR)", group=g_pb, minval=0.0, step=0.1)

// --- Khối lượng ---
g_vol = "📊 Khối lượng"
use_volume = input.bool(false, "Yêu cầu volume > trung bình", group=g_vol)
vol_len    = input.int(20, "Độ dài TB volume", group=g_vol, minval=1)
vol_mult   = input.float(1.0, "Hệ số volume", group=g_vol, minval=0.1, step=0.1)

// --- Mô hình nến ---
use_strict_engulf = input.bool(true, "Engulfing chặt (thân hiện tại > thân trước)", group="🕯️ Mô hình nến")

// --- SL/TP (ATR) ---
g_sl = "🎯 SL/TP (ATR)"
atr_len        = input.int(14, "Độ dài ATR", group=g_sl, minval=1)
rr_ratio       = input.float(1.8, "Tỷ lệ Risk:Reward (RR)", group=g_sl, minval=0.1, step=0.1)
sl_buffer_mult = input.float(0.5, "Đệm ATR cho SL", group=g_sl, minval=0.0, step=0.1)
line_ext_bars  = input.int(30, "Số nến kéo dài SL/TP", group=g_sl, minval=1, maxval=200)

// --- Lọc tín hiệu ---
wait_confirm = input.bool(true, "Chỉ xác nhận khi nến đã đóng (chống repaint)", group="🛡️ Lọc tín hiệu")
min_gap_bars = input.int(0, "Số nến tối thiểu giữa 2 tín hiệu cùng loại", group="🛡️ Lọc tín hiệu", minval=0)

// --- Hiển thị ---
show_bg       = input.bool(true, "Màu nền xu hướng", group="🎨 Hiển thị")
show_sl_tp    = input.bool(true, "Vẽ đường SL/TP", group="🎨 Hiển thị")
max_sltp_sets = input.int(5, "Số bộ SL/TP tối đa", group="🎨 Hiển thị", minval=1, maxval=50)
color_up      = input.color(color.green, "Màu Tăng/MUA", group="🎨 Hiển thị")
color_down    = input.color(color.red,   "Màu Giảm/BÁN", group="🎨 Hiển thị")

// ============================================================
// PHẦN 2: TÍNH TOÁN CHỈ BÁO
// ============================================================

ema_fast = ta.ema(close, ema_fast_len)
ema_slow = ta.ema(close, ema_slow_len)
atr_val  = ta.atr(atr_len)
rsi_val  = ta.rsi(close, rsi_len)

// ADX (Wilder, thủ công)
tr_val    = ta.tr(true)
up_move   = high - high[1]
down_move = low[1] - low
plus_dm   = (up_move > down_move and up_move > 0) ? up_move : 0.0
minus_dm  = (down_move > up_move and down_move > 0) ? down_move : 0.0
smooth_tr    = ta.rma(tr_val, adx_len)
smooth_plus  = ta.rma(plus_dm, adx_len)
smooth_minus = ta.rma(minus_dm, adx_len)
plus_di  = smooth_tr != 0 ? (smooth_plus  / smooth_tr) * 100 : 0.0
minus_di = smooth_tr != 0 ? (smooth_minus / smooth_tr) * 100 : 0.0
dx_val   = (plus_di + minus_di) != 0 ? (math.abs(plus_di - minus_di) / (plus_di + minus_di)) * 100 : 0.0
adx_val  = ta.rma(dx_val, adx_len)

// Trend đa khung (không repaint: dùng nến HTF đã đóng)
htf4_up = request.security(syminfo.tickerid, htf_h4, close > ta.ema(close, htf_ema_len), lookahead=barmerge.lookahead_off)
dtf_up  = request.security(syminfo.tickerid, htf_d,  close > ta.ema(close, htf_ema_len), lookahead=barmerge.lookahead_off)

// ============================================================
// PHẦN 3: MÔ HÌNH NẾN
// ============================================================

body       = math.abs(close - open)
prev_body  = math.abs(close[1] - open[1])
lower_wick = math.min(open, close) - low
upper_wick = high - math.max(open, close)

bull_engulf = close > open and close[1] < open[1] and open <= close[1] and close >= open[1] and (not use_strict_engulf or body > prev_body)
hammer      = body > 0 and lower_wick >= 2 * body and upper_wick <= body * 0.5
bear_engulf = close < open and close[1] > open[1] and open >= close[1] and close <= open[1] and (not use_strict_engulf or body > prev_body)
shooting    = body > 0 and upper_wick >= 2 * body and lower_wick <= body * 0.5

pat_bull = bull_engulf or hammer
pat_bear = bear_engulf or shooting

// ============================================================
// PHẦN 4: CÁC BỘ LỌC HỢP LƯU
// ============================================================

trend_up = ema_fast > ema_slow
trend_dn = ema_fast < ema_slow

adx_ok = adx_val > adx_threshold
di_up  = not use_di_dir or plus_di > minus_di
di_dn  = not use_di_dir or minus_di > plus_di

rsi_buy_ok  = not use_rsi or (rsi_val >= rsi_buy_min and rsi_val <= rsi_buy_max)
rsi_sell_ok = not use_rsi or (rsi_val <= rsi_sell_max and rsi_val >= rsi_sell_min)

// Pullback: giá đã hồi về gần EMA nhanh (mua đáy / bán đỉnh trong xu hướng)
pull_buy_ok  = not use_pullback or (low  <= ema_fast + pullback_atr * atr_val)
pull_sell_ok = not use_pullback or (high >= ema_fast - pullback_atr * atr_val)

avg_vol = ta.sma(volume, vol_len)
vol_ok  = not use_volume or (volume >= vol_mult * avg_vol)

htf4_buy_ok  = not use_htf_h4 or htf4_up
htf4_sell_ok = not use_htf_h4 or not htf4_up
daily_buy_ok  = not use_daily or dtf_up
daily_sell_ok = not use_daily or not dtf_up

// ============================================================
// PHẦN 5: LOGIC TÍN HIỆU
// ============================================================

core_buy  = trend_up and adx_ok and di_up and htf4_buy_ok  and daily_buy_ok  and rsi_buy_ok  and pull_buy_ok  and vol_ok
core_sell = trend_dn and adx_ok and di_dn and htf4_sell_ok and daily_sell_ok and rsi_sell_ok and pull_sell_ok and vol_ok

raw_buy  = core_buy  and pat_bull
raw_sell = core_sell and pat_bear

confirmed_ok = not wait_confirm or barstate.isconfirmed

var int last_buy_bar  = na
var int last_sell_bar = na
gap_ok_buy  = min_gap_bars <= 0 or na(last_buy_bar)  or (bar_index - last_buy_bar)  >= min_gap_bars
gap_ok_sell = min_gap_bars <= 0 or na(last_sell_bar) or (bar_index - last_sell_bar) >= min_gap_bars

buy_signal  = raw_buy  and confirmed_ok and gap_ok_buy
sell_signal = raw_sell and confirmed_ok and gap_ok_sell

if buy_signal
    last_buy_bar := bar_index
if sell_signal
    last_sell_bar := bar_index

// ============================================================
// PHẦN 6: SL / TP
// ============================================================

buy_sl = low  - sl_buffer_mult * atr_val
buy_tp = close + rr_ratio * (close - buy_sl)
sell_sl = high + sl_buffer_mult * atr_val
sell_tp = close - rr_ratio * (sell_sl - close)

// ============================================================
// PHẦN 7: VẼ EMA, NỀN, MŨI TÊN
// ============================================================

plot(ema_fast, "EMA Nhanh", color=color.new(color_up, 0), linewidth=2)
plot(ema_slow, "EMA Chậm",  color=color.new(color_down, 0), linewidth=2)

bg_color = show_bg ? (trend_up ? color.new(color_up, 90) : trend_dn ? color.new(color_down, 90) : na) : na
bgcolor(bg_color, title="Màu nền xu hướng")

plotshape(buy_signal,  "Tín hiệu MUA", shape.triangleup,   location.belowbar, color.new(color_up, 0),   text="MUA", textcolor=color_up,   size=size.small)
plotshape(sell_signal, "Tín hiệu BÁN", shape.triangledown, location.abovebar, color.new(color_down, 0), text="BÁN", textcolor=color_down, size=size.small)

// ============================================================
// PHẦN 8: VẼ SL / TP (quản lý bộ nhớ)
// ============================================================

var array<line>  sl_lines  = array.new<line>()
var array<line>  tp_lines  = array.new<line>()
var array<label> sl_labels = array.new<label>()
var array<label> tp_labels = array.new<label>()

manage_line(array<line> arr, line new_ln, int max_count) =>
    array.push(arr, new_ln)
    if array.size(arr) > max_count
        line.delete(array.shift(arr))

manage_label(array<label> arr, label new_lb, int max_count) =>
    array.push(arr, new_lb)
    if array.size(arr) > max_count
        label.delete(array.shift(arr))

f_draw_sltp(float sl, float tp) =>
    ln_sl = line.new(bar_index, sl, bar_index + line_ext_bars, sl, color=color.new(color_down, 0), width=1, style=line.style_dashed)
    manage_line(sl_lines, ln_sl, max_sltp_sets)
    lb_sl = label.new(bar_index + line_ext_bars, sl, "SL " + str.tostring(sl, format.mintick), color=color.new(color_down, 80), textcolor=color_down, style=label.style_label_left, size=size.small)
    manage_label(sl_labels, lb_sl, max_sltp_sets)
    ln_tp = line.new(bar_index, tp, bar_index + line_ext_bars, tp, color=color.new(color_up, 0), width=1, style=line.style_dashed)
    manage_line(tp_lines, ln_tp, max_sltp_sets)
    lb_tp = label.new(bar_index + line_ext_bars, tp, "TP " + str.tostring(tp, format.mintick), color=color.new(color_up, 80), textcolor=color_up, style=label.style_label_left, size=size.small)
    manage_label(tp_labels, lb_tp, max_sltp_sets)

if show_sl_tp and buy_signal
    f_draw_sltp(buy_sl, buy_tp)
if show_sl_tp and sell_signal
    f_draw_sltp(sell_sl, sell_tp)

// ============================================================
// PHẦN 9: BẢNG TRẠNG THÁI HỢP LƯU
// ============================================================

var table t = table.new(position.top_right, 2, 9, bgcolor=color.new(color.black, 20), border_color=color.new(color.gray, 50), border_width=1)

f_row(int r, string k, string v, color vc) =>
    table.cell(t, 0, r, k, text_color=color.white, text_size=size.small, bgcolor=color.new(color.black, 40))
    table.cell(t, 1, r, v, text_color=vc, text_size=size.small, bgcolor=color.new(color.black, 40))

if barstate.islast
    table.cell(t, 0, 0, "CanNX TC V3", text_color=color.white, text_size=size.small, bgcolor=color.new(color.navy, 20), text_halign=text.align_center)
    table.cell(t, 1, 0, "Trạng thái", text_color=color.white, text_size=size.small, bgcolor=color.new(color.navy, 20), text_halign=text.align_center)
    f_row(1, "EMA Trend",   trend_up ? "Tăng ▲" : trend_dn ? "Giảm ▼" : "─", trend_up ? color_up : trend_dn ? color_down : color.gray)
    f_row(2, "Trend H4",    htf4_up ? "Tăng ▲" : "Giảm ▼", htf4_up ? color_up : color_down)
    f_row(3, "Trend Daily", dtf_up ? "Tăng ▲" : "Giảm ▼", dtf_up ? color_up : color_down)
    f_row(4, "ADX (+DI/−DI)", str.tostring(math.round(adx_val, 1)) + (plus_di > minus_di ? " +" : " −"), adx_ok ? color.lime : color.red)
    f_row(5, "RSI",         str.tostring(math.round(rsi_val, 1)), use_rsi ? color.aqua : color.gray)
    f_row(6, "Pullback EMA", (pull_buy_ok or pull_sell_ok) ? "Gần ✓" : "Xa ✗", (pull_buy_ok or pull_sell_ok) ? color.lime : color.gray)
    f_row(7, "Mô hình nến", pat_bull ? "Bullish" : pat_bear ? "Bearish" : "─", pat_bull ? color_up : pat_bear ? color_down : color.gray)
    sig_txt = buy_signal ? "MUA 🟢" : sell_signal ? "BÁN 🔴" : (wait_confirm and not barstate.isconfirmed and (raw_buy or raw_sell)) ? "Chờ đóng nến…" : "Chờ ─"
    sig_col = buy_signal ? color_up : sell_signal ? color_down : color.gray
    table.cell(t, 0, 8, "Tín hiệu", text_color=color.white, text_size=size.small, bgcolor=color.new(color.black, 30))
    table.cell(t, 1, 8, sig_txt, text_color=sig_col, text_size=size.small, bgcolor=color.new(color.black, 30))

// ============================================================
// PHẦN 10: CẢNH BÁO
// ============================================================

alertcondition(buy_signal,  "TC V3 - Tín hiệu MUA", "CanNX TC V3: Tín hiệu MUA tại {{ticker}} - {{close}}")
alertcondition(sell_signal, "TC V3 - Tín hiệu BÁN", "CanNX TC V3: Tín hiệu BÁN tại {{ticker}} - {{close}}")
