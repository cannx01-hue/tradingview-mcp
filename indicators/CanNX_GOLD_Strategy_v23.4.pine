// © mInvest / CanNX — v23.4 H1 Entry Quality
//@version=6
strategy(title="CanNX - mInvest TC GOLD Strategy v23.4 H1 Entry Quality",
     shorttitle="CNX v23.4",
     overlay=true,
     pyramiding=0,
     initial_capital=10000,
     default_qty_type=strategy.fixed,
     default_qty_value=1,
     commission_type=strategy.commission.percent,
     commission_value=0.02,
     slippage=5,
     margin_long=10,
     margin_short=10,
     process_orders_on_close=true,
     max_bars_back=5000)

// ============================================================================
// v23.4 — Hướng 1: Tắt CGB tường minh, tập trung cải thiện entry quality
//
// PHÁT HIỆN v23.3 (phân tích 6 file backtest FOREXCOM:XAUUSD 2024-2026):
//  A) Hệ thống có phân phối R-multiple BIMODAL: 100% exits tại SL (~−1R)
//     hoặc TP (+3.2R). Không có lệnh nào exit ở 0.5R–2.5R khi không có CGB.
//  B) CGB ở 1.0R trigger bị convert 55% trades từ "đợi TP 3.2R" → "thoát 0.85R"
//     → EV/trade giảm từ 0.722R xuống 0.053R → net profit −80%.
//  C) Trailing tại 2.6R / 5.5×ATR thực tế KHÔNG BAO GIỜ fire — winners đều
//     đi thẳng đến TP mà không cần trailing. Tham số quá rộng.
//  D) WR 41% với RR 3.2 → edge tốt. Vấn đề không phải exit mà là entry quality.
//
// THAY ĐỔI v23.4 (hướng 1):
//  [E1] CGB TẮT TƯỜNG MINH — execute_harness_exit mặc định false cho mọi V23.4
//       preset. Không còn "ẩn CGB bằng trigger $80 không bao giờ chạm".
//       CGB code giữ nguyên làm legacy module, chỉ V23.3 CGB Bench bật để compare.
//  [E2] ADX Rising filter — lọc thêm: adx_val > adx_val[lookback] (ADX đang tăng).
//       Tránh vào lệnh cuối xu hướng khi ADX đang đỉnh và bắt đầu quay đầu.
//  [E3] H4 Candle Confirm filter — H4 nến vừa đóng phải cùng chiều tín hiệu.
//       Thêm xác nhận momentum khung H4, giảm false signal trên H1 counter-trend.
//  [E4] ATR Expansion filter — ATR hiện tại ≥ ATR × atr_exp_ratio (default 1.0).
//       Chỉ vào khi volatility đang mở rộng, tránh vào trong compression low-vol.
//  [E5] Tight Trail preset — trail_trigger_r=1.8, trail_atr_mult=3.5 để test xem
//       có capture được lợi nhuận tốt hơn khi trade đảo chiều từ 1.8-2.5R range.
//  [E6] Entry Quality Score — debug table hiển thị score E2+E3+E4 để dễ tune.
//  Giữ nguyên: process_orders_on_close, max_bars_back, ratchet trailing,
//  just_acted guard, bgcolor fix, new_long/new_short cho plotshape/alert,
//  all risk guards (daily loss, DD circuit breaker, cooldown, friday close).
// ============================================================================

// ---------------------- 01. PRESET / DIRECTION ----------------------
group_main = "01. Preset / Direction"
preset = input.string("V23.4 Final Forward Test", "Preset",
     options=["V23.4 Final Forward Test",
              "V23.4 Tight Trail",
              "V23.4 ADX Rising",
              "V23.4 H4 Confirm",
              "V23.4 ATR Expansion",
              "V23.1 Strict Bench",
              "V23.3 CGB Bench",
              "Custom"],
     group=group_main,
     tooltip="V23.4 Final: CGB OFF tường minh, ADX22 PB2.3 Body0.10 RR3.2 — bản sạch nhất. Các variant 'V23.4 X' thêm 1 filter mới để A/B test riêng lẻ. V23.1 Strict Bench: reference bản tốt nhất trước đây. V23.3 CGB Bench: tái hiện thảm hoạ CGB 1R để compare.")
trade_direction = input.string("Long Only", "Hướng giao dịch", options=["Long Only", "Short Only", "Both"], group=group_main)
confirm_on_close = input.bool(true, "Chỉ xác nhận khi nến đóng", group=group_main)

// ---------------------- 02. SESSION FILTER ----------------------
group_sess = "02. Session Filter"
use_session_filter = input.bool(false, "Bật lọc phiên giao dịch", group=group_sess)
session_london = input.session("0800-1600", "London (Etc/UTC)", group=group_sess)
session_ny = input.session("1300-2200", "New York (Etc/UTC)", group=group_sess)
in_london = not na(time(timeframe.period, session_london, "Etc/UTC"))
in_ny = not na(time(timeframe.period, session_ny, "Etc/UTC"))
session_allowed = not use_session_filter or (in_london or in_ny)
is_friday_utc = dayofweek(time, "Etc/UTC") == dayofweek.friday
friday_close_hour_utc = input.int(20, "Đóng lệnh thứ 6 sau (UTC)", group=group_sess, minval=0, maxval=23)
no_friday_hold = is_friday_utc and hour(time, "Etc/UTC") >= friday_close_hour_utc

// ---------------------- 03. BACKTEST WINDOW ----------------------
group_bt = "03. Backtest Window"
use_date_filter = input.bool(true, "Bật giới hạn thời gian backtest", group=group_bt)
start_time = input.time(timestamp("2020-01-01T00:00:00"), "Ngày bắt đầu", group=group_bt)
end_time = input.time(timestamp("2027-01-01T00:00:00"), "Ngày kết thúc", group=group_bt)
in_date_range = not use_date_filter or (time >= start_time and time <= end_time)

// ---------------------- 04. RISK GUARDS ----------------------
group_guard = "04. Risk Guards"
use_max_daily_loss = input.bool(true, "Bật giới hạn lỗ trong ngày", group=group_guard)
max_daily_loss_pct = input.float(2.0, "Max lỗ/ngày (% equity)", group=group_guard, minval=0.5, step=0.5)
use_max_drawdown = input.bool(true, "Bật circuit breaker drawdown", group=group_guard)
max_drawdown_pct = input.float(15.0, "Max drawdown (%)", group=group_guard, minval=5.0, step=1.0)
dd_reset_mode = input.string("Toàn kỳ", "Reset peak drawdown", options=["Toàn kỳ", "Hàng tháng"], group=group_guard)
use_cooldown = input.bool(true, "Bật cooldown sau loss", group=group_guard)
cooldown_bars = input.int(5, "Số nến cooldown sau khi thua", group=group_guard, minval=1, step=1)

// ---------------------- 05. POSITION SIZING ----------------------
group_size = "05. Position Sizing"
use_risk_sizing = input.bool(true, "Dùng position size theo % risk", group=group_size)
risk_per_trade_pct = input.float(0.25, "Risk per trade (% equity)", group=group_size, minval=0.10, step=0.05)
max_qty_cap = input.float(10, "Max qty (lots)", group=group_size, minval=1, step=1)
fixed_qty_value = input.float(1, "Fixed qty (khi tắt risk sizing)", group=group_size, minval=0.01, step=0.1)

// ---------------------- 06. EMA / TREND ----------------------
group_ema = "06. EMA / Trend"
ema_fast_len = input.int(21, "EMA nhanh", group=group_ema, minval=1)
ema_slow_len = input.int(55, "EMA chậm", group=group_ema, minval=1)
use_ema_slope = input.bool(false, "Lọc thêm độ dốc EMA", group=group_ema)
slope_lookback = input.int(3, "Số nến đo độ dốc EMA", group=group_ema, minval=1)

// ---------------------- 07. HTF FILTER ----------------------
group_htf = "07. HTF EMA Filter"
use_htf_filter = input.bool(true, "Bật EMA filter khung lớn", group=group_htf)
htf_tf = input.timeframe("240", "Khung EMA lớn", group=group_htf)
htf_ema_len = input.int(200, "EMA khung lớn", group=group_htf, minval=1)

// ---------------------- 08. ADX / DMI ----------------------
group_adx = "08. ADX / DMI"
adx_len = input.int(14, "Độ dài ADX", group=group_adx, minval=1)
adx_smoothing = input.int(14, "Làm mượt ADX", group=group_adx, minval=1)
adx_threshold = input.float(18, "Ngưỡng ADX entry", group=group_adx, minval=1, step=0.5)
use_di_filter = input.bool(true, "Lọc DI+ / DI-", group=group_adx)

// ---------------------- 09. CANDLE PATTERN ----------------------
group_candle = "09. Candle Pattern"
use_engulfing = input.bool(true, "Dùng Engulfing", group=group_candle)
use_pinbar = input.bool(true, "Dùng Hammer / Shooting Star", group=group_candle)
wick_body_ratio = input.float(1.8, "Tỷ lệ râu / thân tối thiểu", group=group_candle, minval=1.0, step=0.1)
max_opposite_wick_ratio = input.float(0.7, "Râu ngược tối đa so với thân", group=group_candle, minval=0.0, step=0.1)
use_big_candle_filter = input.bool(true, "Không vào nếu nến tín hiệu quá lớn", group=group_candle)
max_signal_candle_atr = input.float(2.5, "Range nến tín hiệu tối đa theo ATR", group=group_candle, minval=0.5, step=0.1)
use_min_body_filter = input.bool(true, "Lọc nến có body quá nhỏ (doji)", group=group_candle)
min_body_atr = input.float(0.05, "Body tối thiểu theo ATR", group=group_candle, minval=0.0, step=0.01)

// ---------------------- 10. PULLBACK / EXTENSION ----------------------
group_pb = "10. Pullback / Extension"
use_pullback_filter = input.bool(true, "Chỉ lấy tín hiệu gần EMA", group=group_pb)
pullback_atr_mult = input.float(2.7, "Pullback tối đa tới EMA chậm theo ATR", group=group_pb, minval=0.1, step=0.1)
use_max_extension_filter = input.bool(true, "Không vào nếu giá quá xa EMA", group=group_pb)
max_extension_atr = input.float(3.8, "Max extension theo ATR", group=group_pb, minval=0.5, step=0.1)
use_strict_extension = input.bool(true, "Strict extension khi Regime Score thấp", group=group_pb)
strict_extension_atr = input.float(3.6, "Strict extension ATR", group=group_pb, minval=0.5, step=0.1)

// ---------------------- 11. REGIME SCORE ----------------------
group_regime = "11. Regime Score"
use_regime_score = input.bool(true, "Bật Regime Score mềm", group=group_regime)
regime_tf = input.timeframe("240", "Regime TF", group=group_regime)
regime_adx_len = input.int(14, "Regime ADX length", group=group_regime, minval=1)
regime_adx_smoothing = input.int(14, "Regime ADX smoothing", group=group_regime, minval=1)
regime_adx_threshold = input.float(14, "Regime ADX threshold", group=group_regime, minval=1, step=0.5)
min_regime_score = input.int(2, "Regime Score tối thiểu", group=group_regime, minval=0, maxval=4)
use_daily_ema_score = input.bool(true, "Daily EMA tính vào score", group=group_regime)
daily_ema_len = input.int(200, "Daily EMA length", group=group_regime, minval=1)
use_daily_ema_hard_filter = input.bool(false, "Ép cứng: Long chỉ khi trên Daily EMA", group=group_regime)
use_atr_score = input.bool(true, "ATR State tính vào score", group=group_regime)
atr_state_len = input.int(100, "ATR trung bình length", group=group_regime, minval=5)
min_atr_state_ratio = input.float(0.70, "ATR hiện tại / ATR TB tối thiểu", group=group_regime, minval=0.1, step=0.05)

// ---------------------- 12. VOLUME / RANGE ----------------------
group_vol = "12. Volume / Range Filter"
use_volume_filter = input.bool(false, "Bật lọc volume", group=group_vol)
vol_len = input.int(20, "Volume MA length", group=group_vol, minval=1)
min_vol_ratio = input.float(0.6, "Volume tối thiểu / MA", group=group_vol, minval=0.1, step=0.1)
use_range_filter = input.bool(false, "Bật lọc range nến", group=group_vol)
max_range_atr = input.float(2.5, "Max range nến theo ATR", group=group_vol, minval=0.5, step=0.1)

// ---------------------- 13. RISK / EXIT ----------------------
group_risk = "13. Risk / Exit"
atr_len = input.int(14, "ATR length", group=group_risk, minval=1)
sl_atr_mult = input.float(1.0, "Initial SL theo ATR", group=group_risk, minval=0.1, step=0.05)
rr_ratio = input.float(2.15, "Take Profit RR", group=group_risk, minval=0.5, step=0.05)
use_trailing = input.bool(true, "Bật ATR trailing stop", group=group_risk)
trail_atr_mult = input.float(3.6, "Trailing ATR multiplier", group=group_risk, minval=0.5, step=0.1)
trail_trigger_r = input.float(1.65, "Chỉ trailing sau khi đạt R", group=group_risk, minval=0.1, step=0.05)
use_breakeven = input.bool(false, "Bật breakeven", group=group_risk)
breakeven_trigger_r = input.float(1.5, "Breakeven trigger R", group=group_risk, minval=0.1, step=0.05)
breakeven_offset_r = input.float(0.05, "Breakeven offset R", group=group_risk, minval=0.0, step=0.01)
use_time_stop = input.bool(false, "Bật time stop", group=group_risk)
time_stop_bars = input.int(220, "Time stop bars", group=group_risk, minval=1)

// ---------------------- 14. ENTRY QUALITY v23.4 (mới) ----------------------
// [E2] ADX Rising — ADX đang tăng, không chỉ vượt ngưỡng
// [E3] H4 Candle Confirm — H4 nến vừa đóng cùng chiều tín hiệu
// [E4] ATR Expansion — volatility đang mở rộng (không vào trong compression)
group_eq = "14. Entry Quality v23.4 (thử nghiệm)"
use_adx_rising = input.bool(false, "[E2] ADX Rising: ADX phải đang tăng",
     group=group_eq,
     tooltip="adx_val > adx_val[adx_rising_lookback]. Tránh vào cuối xu hướng khi ADX đỉnh và quay đầu. Thử nghiệm riêng lẻ với preset V23.4 ADX Rising.")
adx_rising_lookback = input.int(1, "ADX Rising lookback (nến)", group=group_eq, minval=1, maxval=5)
use_htf_candle_confirm = input.bool(false, "[E3] H4 Candle Confirm: nến H4 phải cùng chiều",
     group=group_eq,
     tooltip="Nến H4 vừa đóng phải bullish cho Long, bearish cho Short. Dùng [1] để tránh repaint. Khung sử dụng là htf_tf (group 07). Thử nghiệm riêng lẻ với preset V23.4 H4 Confirm.")
use_atr_expansion = input.bool(false, "[E4] ATR Expansion: ATR ≥ ATR trung bình × hệ số",
     group=group_eq,
     tooltip="atr_val >= atr_avg * atr_exp_factor. Chỉ vào khi volatility ≥ mức trung bình, tránh vào trong low-vol compression trước breakout. Thử nghiệm riêng lẻ với preset V23.4 ATR Expansion.")
atr_exp_factor = input.float(1.00, "ATR Expansion factor (× ATR avg)", group=group_eq, minval=0.5, step=0.05,
     tooltip="1.00 = ATR phải ≥ ATR trung bình (bằng hoặc cao hơn). 1.10 = ATR phải cao hơn 10% so với trung bình.")

// ---------------------- 15. CGB LEGACY (tắt theo mặc định v23.4) ----------------------
// [E1] CGB giờ là module legacy, tắt tường minh thay vì dùng trigger $80 không bao giờ chạm.
// Chỉ bật khi preset = "V23.3 CGB Bench" để reproduce kết quả nghiên cứu.
group_harness = "15. CGB Legacy (mặc định OFF — xem v23.3)"
execute_harness_exit = input.bool(false, "THỰC THI CGB Exit (legacy, mặc định OFF)",
     group=group_harness,
     tooltip="[E1] v23.4 TẮT tường minh. Data analysis v23.3 cho thấy CGB ở 1.0R trigger phá huỷ 80% lợi nhuận do hệ thống này là bimodal TP/SL. Chỉ bật để chạy preset V23.3 CGB Bench.")
trigger_mode = input.string("R-multiple", "Trigger mode (legacy)", options=["R-multiple","% Equity","USD cố định"], group=group_harness)
trigger_r_mult = input.float(1.0, "Trigger R-multiple (legacy)", group=group_harness, minval=0.3, step=0.1)
trigger_pct_equity = input.float(0.5, "Trigger % equity (legacy)", group=group_harness, minval=0.1, step=0.1)
trigger_usd_fixed = input.float(50.0, "Trigger USD (legacy)", group=group_harness, minval=10.0, step=5.0)
harness_giveback_pct = input.float(40.0, "Giveback % (legacy)", group=group_harness, minval=5.0, maxval=95.0, step=5.0)
min_keep_r_mult = input.float(0.30, "Min keep R-multiple (legacy)", group=group_harness, minval=0.0, step=0.05)
min_keep_pct_equity = input.float(0.3, "Min keep % equity (legacy)", group=group_harness, minval=0.0, step=0.1)
min_keep_usd_fixed = input.float(20.0, "Min keep USD (legacy)", group=group_harness, minval=0.0, step=5.0)
harness_near_buffer = input.float(10.0, "Near buffer % (legacy)", group=group_harness, minval=1.0, step=1.0)
use_intrabar_mfe = input.bool(true, "Intrabar giveback (legacy)", group=group_harness)
use_intrabar_trigger = input.bool(true, "Intrabar trigger (legacy)", group=group_harness)
use_commission_guard = input.bool(true, "Commission Guard (legacy)", group=group_harness)
commission_guard_mult = input.float(1.5, "Commission Guard mult (legacy)", group=group_harness, minval=0.5, step=0.5)
commission_pct_estimate = input.float(0.02, "Commission % estimate", group=group_harness, minval=0.0, step=0.01)
show_harness_markers = input.bool(false, "Hiển thị marker CGB (legacy)", group=group_harness)

// ---------------------- 16. DISPLAY ----------------------
group_disp = "16. Display / Debug"
show_bg = input.bool(true, "Màu nền xu hướng", group=group_disp)
show_table = input.bool(true, "Bảng debug", group=group_disp)
show_shapes = input.bool(true, "Hiển thị tín hiệu", group=group_disp)
show_block_markers = input.bool(false, "Marker filter bị chặn", group=group_disp)
show_eq_markers = input.bool(true, "Marker Entry Quality bị chặn (EQ2/EQ3/EQ4)", group=group_disp,
     tooltip="Hiện marker khi có tín hiệu cơ bản nhưng bị lọc bởi E2/E3/E4. Chỉ hữu ích khi đang bật ≥1 filter EQ.")
show_session_badge = input.bool(true, "Badge phiên trên chart", group=group_disp)

// ============================================================================
// PRESET OVERRIDES
// ============================================================================
is_v234 = str.startswith(preset, "V23.4")
is_v231_bench = preset == "V23.1 Strict Bench"
is_v233_cgb = preset == "V23.3 CGB Bench"
is_any_package = is_v234 or is_v231_bench or is_v233_cgb

// Base package — chung cho tất cả preset trừ Custom
if is_any_package
    trade_direction := "Long Only"
    use_risk_sizing := true
    risk_per_trade_pct := 0.25
    max_qty_cap := 10
    min_regime_score := 3
    use_strict_extension := true
    strict_extension_atr := 3.0
    use_session_filter := false
    use_volume_filter := false
    use_range_filter := false
    max_daily_loss_pct := 0.75
    max_drawdown_pct := 5.0
    dd_reset_mode := "Hàng tháng"
    use_breakeven := false
    use_time_stop := false
    rr_ratio := 3.2
    use_trailing := true
    trail_trigger_r := 2.6
    trail_atr_mult := 5.5
    // [E1] CGB OFF tường minh cho tất cả preset trừ V23.3 CGB Bench
    execute_harness_exit := false
    // Entry quality filters: tắt mặc định cho base
    use_adx_rising := false
    use_htf_candle_confirm := false
    use_atr_expansion := false

// V23.4 group: entry config giống V23.1 best + CGB OFF
if is_v234
    adx_threshold := 22.0
    pullback_atr_mult := 2.3
    min_body_atr := 0.10

// [E5] V23.4 Tight Trail: trailing tighter để test capture mid-run reversals
if preset == "V23.4 Tight Trail"
    trail_trigger_r := 1.8
    trail_atr_mult := 3.5

// [E2] V23.4 ADX Rising: ADX Rising filter bật, test riêng lẻ
if preset == "V23.4 ADX Rising"
    use_adx_rising := true
    adx_rising_lookback := 1

// [E3] V23.4 H4 Confirm: H4 candle confirm bật, test riêng lẻ
if preset == "V23.4 H4 Confirm"
    use_htf_candle_confirm := true

// [E4] V23.4 ATR Expansion: ATR expansion filter bật, test riêng lẻ
if preset == "V23.4 ATR Expansion"
    use_atr_expansion := true
    atr_exp_factor := 1.00

// V23.1 Strict Bench: reference tốt nhất, CGB OFF tường minh
if is_v231_bench
    adx_threshold := 22.0
    pullback_atr_mult := 2.3
    min_body_atr := 0.10

// V23.3 CGB Bench: reproduce V23.3's CGB 1.0R để compare
if is_v233_cgb
    adx_threshold := 22.0
    pullback_atr_mult := 2.3
    min_body_atr := 0.10
    execute_harness_exit := true
    trigger_mode := "R-multiple"
    trigger_r_mult := 1.0
    min_keep_r_mult := 0.30
    use_intrabar_mfe := true
    use_intrabar_trigger := true
    use_commission_guard := true
    commission_guard_mult := 1.5

session_allowed := not use_session_filter or (in_london or in_ny)

// ============================================================================
// CORE CALCULATIONS
// ============================================================================
ema_fast = ta.ema(close, ema_fast_len)
ema_slow = ta.ema(close, ema_slow_len)
atr_val = ta.atr(atr_len)
atr_avg = ta.sma(atr_val, atr_state_len)
atr_ratio = atr_avg > 0 ? atr_val / atr_avg : 1.0

[plus_di, minus_di, adx_val] = ta.dmi(adx_len, adx_smoothing)

f_confirmed_dmi(_len, _smooth) =>
    [p, m, a] = ta.dmi(_len, _smooth)
    [p[1], m[1], a[1]]

htf_ema = request.security(syminfo.tickerid, htf_tf, ta.ema(close, htf_ema_len)[1], barmerge.gaps_off, barmerge.lookahead_off)
daily_ema = request.security(syminfo.tickerid, "D", ta.ema(close, daily_ema_len)[1], barmerge.gaps_off, barmerge.lookahead_off)
[regime_plus_di, regime_minus_di, regime_adx] = request.security(syminfo.tickerid, regime_tf, f_confirmed_dmi(regime_adx_len, regime_adx_smoothing), barmerge.gaps_off, barmerge.lookahead_off)

// [E3] H4 Candle Confirm: lấy close/open nến H4 đã đóng ([1]) qua htf_tf — tránh repaint
htf_close_prev = request.security(syminfo.tickerid, htf_tf, close[1], barmerge.gaps_off, barmerge.lookahead_off)
htf_open_prev = request.security(syminfo.tickerid, htf_tf, open[1], barmerge.gaps_off, barmerge.lookahead_off)
h4_bull_candle = htf_close_prev > htf_open_prev
h4_bear_candle = htf_close_prev < htf_open_prev

// Trend
ema_slope_up = ema_fast > ema_fast[slope_lookback] and ema_slow >= ema_slow[slope_lookback]
ema_slope_down = ema_fast < ema_fast[slope_lookback] and ema_slow <= ema_slow[slope_lookback]
trend_up = ema_fast > ema_slow and (not use_ema_slope or ema_slope_up)
trend_down = ema_fast < ema_slow and (not use_ema_slope or ema_slope_down)

htf_up_ok = not use_htf_filter or close > htf_ema
htf_down_ok = not use_htf_filter or close < htf_ema
adx_ok = adx_val >= adx_threshold
di_buy_ok = not use_di_filter or plus_di > minus_di
di_sell_ok = not use_di_filter or minus_di > plus_di
ema_distance_atr = atr_val > 0 ? math.abs(close - ema_slow) / atr_val : 0.0
pullback_ok = not use_pullback_filter or ema_distance_atr <= pullback_atr_mult
extension_ok = not use_max_extension_filter or ema_distance_atr <= max_extension_atr

// Candle
body = math.abs(close - open)
body_atr = atr_val > 0 ? body / atr_val : 0.0
real_body = math.max(body, syminfo.mintick * 10)
lower_wick = math.min(open, close) - low
upper_wick = high - math.max(open, close)
signal_range_atr = atr_val > 0 ? (high - low) / atr_val : 0.0
big_candle_ok = not use_big_candle_filter or signal_range_atr <= max_signal_candle_atr
min_body_ok = not use_min_body_filter or body_atr >= min_body_atr

prev_bear = close[1] < open[1]
prev_bull = close[1] > open[1]
curr_bull = close > open
curr_bear = close < open
bullish_engulfing = curr_bull and prev_bear and open <= close[1] and close >= open[1]
bearish_engulfing = curr_bear and prev_bull and open >= close[1] and close <= open[1]
hammer = curr_bull and lower_wick >= wick_body_ratio * real_body and upper_wick <= max_opposite_wick_ratio * real_body
shooting_star = curr_bear and upper_wick >= wick_body_ratio * real_body and lower_wick <= max_opposite_wick_ratio * real_body
bullish_pattern = (use_engulfing and bullish_engulfing) or (use_pinbar and hammer)
bearish_pattern = (use_engulfing and bearish_engulfing) or (use_pinbar and shooting_star)

// Regime Score — component tắt = PASS
score_daily_long = not use_daily_ema_score ? 1 : close > daily_ema ? 1 : 0
score_daily_short = not use_daily_ema_score ? 1 : close < daily_ema ? 1 : 0
score_dmi_long = regime_plus_di > regime_minus_di ? 1 : 0
score_dmi_short = regime_minus_di > regime_plus_di ? 1 : 0
score_adx_r = regime_adx >= regime_adx_threshold ? 1 : 0
score_atr = not use_atr_score ? 1 : atr_ratio >= min_atr_state_ratio ? 1 : 0
regime_score_long = score_daily_long + score_dmi_long + score_adx_r + score_atr
regime_score_short = score_daily_short + score_dmi_short + score_adx_r + score_atr
regime_long_ok = not use_regime_score or regime_score_long >= min_regime_score
regime_short_ok = not use_regime_score or regime_score_short >= min_regime_score
daily_hard_long_ok = not use_daily_ema_hard_filter or close > daily_ema
daily_hard_short_ok = not use_daily_ema_hard_filter or close < daily_ema
strict_extension_ok_long = not use_strict_extension or regime_score_long > min_regime_score or ema_distance_atr <= strict_extension_atr
strict_extension_ok_short = not use_strict_extension or regime_score_short > min_regime_score or ema_distance_atr <= strict_extension_atr

vol_avg = ta.sma(volume, vol_len)
vol_ratio = vol_avg > 0 ? volume / vol_avg : 1.0
volume_ok = not use_volume_filter or vol_ratio >= min_vol_ratio
range_ok = not use_range_filter or signal_range_atr <= max_range_atr

// ============================================================================
// [E2–E4] ENTRY QUALITY FILTERS v23.4
// ============================================================================

// [E2] ADX Rising: ADX đang có xu hướng tăng — tránh vào cuối trend khi ADX quay đầu
adx_rising = adx_val > adx_val[adx_rising_lookback]
adx_rising_ok = not use_adx_rising or adx_rising

// [E3] H4 Candle Confirm: nến H4 vừa đóng phải xác nhận hướng — thêm momentum H4
htf_candle_long_ok = not use_htf_candle_confirm or h4_bull_candle
htf_candle_short_ok = not use_htf_candle_confirm or h4_bear_candle

// [E4] ATR Expansion: ATR hiện tại ≥ ATR avg × factor — tránh vào trong low-vol compression
atr_expansion_ok = not use_atr_expansion or (atr_avg > 0 and atr_val >= atr_avg * atr_exp_factor)

// [E6] Entry Quality Score: đếm số filter EQ đang pass (để debug hiệu quả từng filter)
eq2_pass = adx_rising
eq3_long_pass = h4_bull_candle
eq4_pass = atr_avg > 0 and atr_val >= atr_avg * atr_exp_factor
eq_score_long = (eq2_pass ? 1 : 0) + (eq3_long_pass ? 1 : 0) + (eq4_pass ? 1 : 0)

// ============================================================================
// RISK GUARDS
// ============================================================================
var float day_start_equity = na
var float daily_pnl_pct = 0.0
is_new_day = ta.change(time("D")) != 0
if na(day_start_equity) or is_new_day
    day_start_equity := strategy.equity
daily_pnl_pct := day_start_equity > 0 ? (strategy.equity - day_start_equity) / day_start_equity * 100.0 : 0.0
daily_loss_breached = use_max_daily_loss and daily_pnl_pct <= -max_daily_loss_pct

var float peak_equity = na
is_new_month = ta.change(time("M")) != 0
if na(peak_equity) or (dd_reset_mode == "Hàng tháng" and is_new_month)
    peak_equity := strategy.equity
else
    peak_equity := math.max(peak_equity, strategy.equity)
current_dd_pct = peak_equity > 0 ? (strategy.equity - peak_equity) / peak_equity * 100.0 : 0.0
dd_breached = use_max_drawdown and current_dd_pct <= -max_drawdown_pct

var int last_loss_bar = na
new_closed_trade = strategy.closedtrades > nz(strategy.closedtrades[1])
last_trade_loss = strategy.closedtrades > 0 and new_closed_trade and strategy.closedtrades.profit(strategy.closedtrades - 1) < 0
if last_trade_loss
    last_loss_bar := bar_index
bars_since_loss = na(last_loss_bar) ? 9999 : bar_index - last_loss_bar
in_cooldown = use_cooldown and not na(last_loss_bar) and bars_since_loss < cooldown_bars

can_long = (trade_direction == "Long Only" or trade_direction == "Both")
can_short = (trade_direction == "Short Only" or trade_direction == "Both")
bar_ok = not confirm_on_close or barstate.isconfirmed
risk_guards_ok = not daily_loss_breached and not dd_breached and not in_cooldown and session_allowed and not no_friday_hold

// ============================================================================
// SIGNALS — thêm [E2]/[E3]/[E4] vào điều kiện entry
// ============================================================================
raw_buy  = trend_up   and htf_up_ok   and adx_ok and di_buy_ok  and pullback_ok and extension_ok and strict_extension_ok_long  and big_candle_ok and min_body_ok and volume_ok and range_ok and bullish_pattern and regime_long_ok  and daily_hard_long_ok  and adx_rising_ok and htf_candle_long_ok  and atr_expansion_ok
raw_sell = trend_down and htf_down_ok and adx_ok and di_sell_ok and pullback_ok and extension_ok and strict_extension_ok_short and big_candle_ok and min_body_ok and volume_ok and range_ok and bearish_pattern and regime_short_ok and daily_hard_short_ok and adx_rising_ok and htf_candle_short_ok and atr_expansion_ok

buy_signal  = in_date_range and bar_ok and can_long  and risk_guards_ok and raw_buy
sell_signal = in_date_range and bar_ok and can_short and risk_guards_ok and raw_sell

// ============================================================================
// POSITION STATE
// ============================================================================
var float entry_price = na
var float entry_risk = na
var float entry_sl = na
var float entry_tp = na
var float entry_atr = na
var int entry_bar = na
var float highest_since_entry = na
var float lowest_since_entry = na
var float max_strategy_open_profit = na
var float cgb_max_giveback_seen = na
var int cgb_trigger_bars = 0
var int cgb_giveback_bars = 0
var int cgb_keep_bars = 0
var bool exit_called_this_bar = false
var float best_long_stop = na
var float best_short_stop = na
var int cgb_fired_count = 0
var float cgb_profit_captured_total = 0.0

new_long  = buy_signal  and strategy.position_size <= 0
new_short = sell_signal and strategy.position_size >= 0

risk_candidate    = sl_atr_mult * atr_val
long_sl_candidate = close - risk_candidate
long_tp_candidate = close + rr_ratio * risk_candidate
short_sl_candidate = close + risk_candidate
short_tp_candidate = close - rr_ratio * risk_candidate

calc_qty_from_risk(float risk_amt) =>
    sl_dist = sl_atr_mult * atr_val
    pv = syminfo.pointvalue
    sl_dist > 0 and pv > 0 ? risk_amt / (sl_dist * pv) : 1.0

risk_amt  = strategy.equity * risk_per_trade_pct / 100.0
trade_qty = use_risk_sizing ? math.min(calc_qty_from_risk(risk_amt), max_qty_cap) : fixed_qty_value

if new_long and risk_candidate > 0
    strategy.close("Short", comment="Close Short on Buy")
    entry_price := close
    entry_sl := long_sl_candidate
    entry_risk := risk_candidate
    entry_tp := long_tp_candidate
    entry_atr := atr_val
    entry_bar := bar_index
    highest_since_entry := high
    lowest_since_entry := low
    max_strategy_open_profit := 0.0
    cgb_max_giveback_seen := 0.0
    cgb_trigger_bars := 0
    cgb_giveback_bars := 0
    cgb_keep_bars := 0
    best_long_stop := na
    best_short_stop := na
    strategy.entry("Long", strategy.long, qty=trade_qty, comment="BUY v23.4 H1")
    strategy.exit("Long Exit", from_entry="Long", stop=long_sl_candidate, limit=long_tp_candidate, comment="Long Exit")

if new_short and risk_candidate > 0
    strategy.close("Long", comment="Close Long on Sell")
    entry_price := close
    entry_sl := short_sl_candidate
    entry_risk := risk_candidate
    entry_tp := short_tp_candidate
    entry_atr := atr_val
    entry_bar := bar_index
    highest_since_entry := high
    lowest_since_entry := low
    max_strategy_open_profit := 0.0
    cgb_max_giveback_seen := 0.0
    cgb_trigger_bars := 0
    cgb_giveback_bars := 0
    cgb_keep_bars := 0
    best_long_stop := na
    best_short_stop := na
    strategy.entry("Short", strategy.short, qty=trade_qty, comment="SELL v23.4 H1")
    strategy.exit("Short Exit", from_entry="Short", stop=short_sl_candidate, limit=short_tp_candidate, comment="Short Exit")

just_acted = new_long or new_short
in_long  = strategy.position_size > 0 and not just_acted
in_short = strategy.position_size < 0 and not just_acted
in_trade = in_long or in_short
bars_in_trade = in_trade and not na(entry_bar) ? bar_index - entry_bar : 0

if in_trade
    highest_since_entry := na(highest_since_entry) ? high : math.max(highest_since_entry, high)
    lowest_since_entry  := na(lowest_since_entry)  ? low  : math.min(lowest_since_entry,  low)

current_r = 0.0
if in_long  and not na(entry_price) and entry_risk > 0
    current_r := (close - entry_price) / entry_risk
if in_short and not na(entry_price) and entry_risk > 0
    current_r := (entry_price - close) / entry_risk

is_new_bar = ta.change(time) != 0
if is_new_bar
    exit_called_this_bar := false

// ============================================================================
// EXIT MANAGEMENT
// ============================================================================
if in_long and entry_risk > 0
    long_stop = entry_sl
    if use_breakeven and current_r >= breakeven_trigger_r
        long_stop := math.max(long_stop, entry_price + breakeven_offset_r * entry_risk)
    if use_trailing and current_r >= trail_trigger_r
        long_stop := math.max(long_stop, nz(highest_since_entry, high) - trail_atr_mult * atr_val)
    best_long_stop := na(best_long_stop) ? long_stop : math.max(best_long_stop, long_stop)
    strategy.exit("Long Exit", from_entry="Long", stop=best_long_stop, limit=entry_tp, comment="Long Exit")

if in_short and entry_risk > 0
    short_stop = entry_sl
    if use_breakeven and current_r >= breakeven_trigger_r
        short_stop := math.min(short_stop, entry_price - breakeven_offset_r * entry_risk)
    if use_trailing and current_r >= trail_trigger_r
        short_stop := math.min(short_stop, nz(lowest_since_entry, low) + trail_atr_mult * atr_val)
    best_short_stop := na(best_short_stop) ? short_stop : math.min(best_short_stop, short_stop)
    strategy.exit("Short Exit", from_entry="Short", stop=best_short_stop, limit=entry_tp, comment="Short Exit")

if use_time_stop and in_trade and bars_in_trade >= time_stop_bars
    strategy.close(in_long ? "Long" : "Short", comment="Time Stop")
    exit_called_this_bar := true

// ============================================================================
// CGB LEGACY MODULE (chỉ active khi execute_harness_exit=true = V23.3 CGB Bench)
// ============================================================================
strategy_profit_now = in_trade ? strategy.openprofit : 0.0
if in_trade
    max_strategy_open_profit := na(max_strategy_open_profit) ? strategy_profit_now : math.max(max_strategy_open_profit, strategy_profit_now)

float r_position_value = entry_risk > 0 ? entry_risk * math.abs(strategy.position_size) * syminfo.pointvalue : 0.0
float trigger_value = trigger_mode == "R-multiple" ? trigger_r_mult * r_position_value : trigger_mode == "% Equity" ? strategy.equity * trigger_pct_equity / 100.0 : trigger_usd_fixed
float min_keep_value = trigger_mode == "R-multiple" ? min_keep_r_mult * r_position_value : trigger_mode == "% Equity" ? strategy.equity * min_keep_pct_equity / 100.0 : min_keep_usd_fixed

float est_commission_per_trade = na
if not na(entry_price) and math.abs(strategy.position_size) > 0
    est_commission_per_trade := math.abs(strategy.position_size) * syminfo.pointvalue * entry_price * commission_pct_estimate / 100.0 * 2.0
float commission_guard_min = use_commission_guard and not na(est_commission_per_trade) ? commission_guard_mult * est_commission_per_trade : 0.0

max_profit_for_gb = math.max(nz(max_strategy_open_profit, 0), 0)
currency_giveback_pct = max_profit_for_gb > 0 ? math.max(0.0, (max_profit_for_gb - strategy_profit_now) / max_profit_for_gb * 100.0) : 0.0

float intrabar_gb_pct = currency_giveback_pct
if use_intrabar_mfe and in_trade
    if in_long and not na(highest_since_entry) and not na(entry_price)
        hi = nz(highest_since_entry, high)
        if hi > entry_price and (hi - entry_price) > 0
            intrabar_gb_pct := math.max(currency_giveback_pct, math.max(0.0, (hi - low) / (hi - entry_price) * 100.0))
    if in_short and not na(lowest_since_entry) and not na(entry_price)
        lo = nz(lowest_since_entry, low)
        if lo < entry_price and (entry_price - lo) > 0
            intrabar_gb_pct := math.max(currency_giveback_pct, math.max(0.0, (high - lo) / (entry_price - lo) * 100.0))

float intrabar_max_profit = max_profit_for_gb
if use_intrabar_trigger and in_trade and not na(entry_price) and math.abs(strategy.position_size) > 0
    pv_pos = math.abs(strategy.position_size) * syminfo.pointvalue
    if in_long  and not na(highest_since_entry)
        intrabar_max_profit := math.max(max_profit_for_gb, (nz(highest_since_entry, high) - entry_price) * pv_pos)
    if in_short and not na(lowest_since_entry)
        intrabar_max_profit := math.max(max_profit_for_gb, (entry_price - nz(lowest_since_entry, low)) * pv_pos)

float trigger_profit_basis = use_intrabar_trigger ? intrabar_max_profit : max_profit_for_gb
commission_guard_pass = not use_commission_guard or strategy_profit_now >= commission_guard_min
currency_trigger_raw = in_trade and trigger_profit_basis >= trigger_value
currency_giveback_pass = in_trade and intrabar_gb_pct >= harness_giveback_pct
currency_keep_pass = in_trade and strategy_profit_now >= min_keep_value
currency_near_raw = currency_trigger_raw and intrabar_gb_pct >= math.max(harness_giveback_pct - harness_near_buffer, 0.0) and intrabar_gb_pct < harness_giveback_pct and currency_keep_pass and commission_guard_pass
currency_exit_raw = currency_trigger_raw and currency_giveback_pass and currency_keep_pass and commission_guard_pass

if in_trade
    cgb_max_giveback_seen := na(cgb_max_giveback_seen) ? intrabar_gb_pct : math.max(cgb_max_giveback_seen, intrabar_gb_pct)
    cgb_trigger_bars += currency_trigger_raw ? 1 : 0
    cgb_giveback_bars += currency_giveback_pass ? 1 : 0
    cgb_keep_bars += currency_keep_pass ? 1 : 0

currency_exit_condition = barstate.isconfirmed and execute_harness_exit and currency_exit_raw
if currency_exit_condition
    strategy.close(in_long ? "Long" : "Short", comment="CGB Exit (legacy)")
    exit_called_this_bar := true
    cgb_fired_count += 1
    cgb_profit_captured_total += strategy_profit_now

// Risk guard exits
if daily_loss_breached and in_trade
    strategy.close(in_long ? "Long" : "Short", comment="Daily Loss Limit")
    exit_called_this_bar := true

if dd_breached and in_trade
    strategy.close(in_long ? "Long" : "Short", comment="DD Circuit Breaker")
    exit_called_this_bar := true

if no_friday_hold and in_trade
    strategy.close(in_long ? "Long" : "Short", comment="Friday Close")
    exit_called_this_bar := true

// Reset state
if strategy.position_size == 0 and strategy.position_size[1] != 0 and not just_acted
    entry_price := na
    entry_sl := na
    entry_risk := na
    entry_tp := na
    entry_atr := na
    entry_bar := na
    highest_since_entry := na
    lowest_since_entry := na
    max_strategy_open_profit := na
    best_long_stop := na
    best_short_stop := na

// ============================================================================
// PLOTS
// ============================================================================
plot(ema_fast, "EMA Fast", color=color.new(color.green, 0), linewidth=2)
plot(ema_slow, "EMA Slow", color=color.new(color.red, 0), linewidth=2)
plot(htf_ema, "HTF EMA", color=color.new(color.orange, 0), linewidth=1)
plot(daily_ema, "Daily EMA", color=color.new(color.blue, 30), linewidth=1)

bgcolor(show_bg ? (trend_up ? color.new(color.green, 91) : trend_down ? color.new(color.red, 91) : na) : na)

plotshape(show_shapes and new_long,  title="BUY",  style=shape.triangleup,   location=location.belowbar, color=color.new(color.lime, 0), text="BUY",  textcolor=color.lime, size=size.small)
plotshape(show_shapes and new_short, title="SELL", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0),  text="SELL", textcolor=color.red,  size=size.small)

// CGB markers (chỉ hiện khi show_harness_markers = true và execute_harness_exit bật)
plotshape(show_harness_markers and currency_near_raw,  title="CGB Near", style=shape.labeldown, location=location.abovebar, color=color.new(color.aqua,    0), text="CGB~", textcolor=color.black, size=size.tiny)
plotshape(show_harness_markers and currency_exit_raw,  title="CGB Raw",  style=shape.labeldown, location=location.abovebar, color=color.new(color.blue,    0), text="CGB",  textcolor=color.white, size=size.tiny)
plotshape(show_harness_markers and exit_called_this_bar and execute_harness_exit, title="EXIT", style=shape.labeldown, location=location.abovebar, color=color.new(color.fuchsia,0), text="EXIT",textcolor=color.white, size=size.tiny)

// Block markers — base filters
base_bull_candidate = bullish_pattern and trend_up and min_body_ok
plotshape(show_block_markers and base_bull_candidate and not regime_long_ok, title="Blk Regime", style=shape.circle, location=location.belowbar, color=color.new(color.orange, 0), text="RG", size=size.tiny)
plotshape(show_block_markers and base_bull_candidate and regime_long_ok and not big_candle_ok, title="Blk BC", style=shape.circle, location=location.belowbar, color=color.new(color.gray, 0), text="BC", size=size.tiny)
plotshape(show_block_markers and base_bull_candidate and regime_long_ok and big_candle_ok and not extension_ok, title="Blk Ext", style=shape.circle, location=location.belowbar, color=color.new(color.teal, 0), text="EX", size=size.tiny)

// [E6] Entry Quality block markers — giúp đếm bao nhiêu tín hiệu bị lọc bởi E2/E3/E4
base_passed = base_bull_candidate and regime_long_ok and big_candle_ok and extension_ok and adx_ok and di_buy_ok and pullback_ok and min_body_ok
plotshape(show_eq_markers and base_passed and not adx_rising_ok,          title="EQ2 Blk", style=shape.xcross, location=location.belowbar, color=color.new(color.yellow,  0), text="E2", size=size.tiny)
plotshape(show_eq_markers and base_passed and adx_rising_ok and not htf_candle_long_ok,  title="EQ3 Blk", style=shape.xcross, location=location.belowbar, color=color.new(color.purple,  0), text="E3", size=size.tiny)
plotshape(show_eq_markers and base_passed and adx_rising_ok and htf_candle_long_ok and not atr_expansion_ok, title="EQ4 Blk", style=shape.xcross, location=location.belowbar, color=color.new(color.maroon, 0), text="E4", size=size.tiny)

var table session_t = table.new(position.top_left, 1, 1, bgcolor=color.new(color.black, 60), border_width=0)
if show_session_badge and barstate.islast
    table.cell(session_t, 0, 0, in_london ? "LONDON" : in_ny ? "NEW YORK" : "OFF-HOURS",
         text_color=in_london ? color.yellow : in_ny ? color.aqua : color.gray, text_size=size.large)

// Hidden plots
plot(regime_score_long,  "Regime Score Long",  display=display.none)
plot(regime_score_short, "Regime Score Short", display=display.none)
plot(daily_pnl_pct,  "Daily PnL %",   display=display.none)
plot(current_dd_pct, "Current DD %",  display=display.none)
plot(adx_rising ? 1.0 : 0.0, "ADX Rising",    display=display.none)
plot(h4_bull_candle ? 1.0 : 0.0, "H4 Bull",   display=display.none)
plot(atr_expansion_ok ? 1.0 : 0.0, "ATR Exp", display=display.none)
plot(eq_score_long, "EQ Score Long", display=display.none)
plot(strategy_profit_now, "Open Profit", display=display.none)
plot(nz(max_strategy_open_profit), "Max Open Profit", display=display.none)
plot(cgb_fired_count, "CGB Fired Count", display=display.none)

// ============================================================================
// DEBUG TABLE
// ============================================================================
var table t = table.new(position.top_right, 2, 30,
     bgcolor=color.new(color.black, 25), border_color=color.new(color.gray, 60), border_width=1)
if show_table and barstate.islast
    table.cell(t, 0, 0, "v23.4 Entry Quality", text_color=color.white, bgcolor=color.new(color.navy, 15))
    table.cell(t, 1, 0, preset, text_color=color.white, bgcolor=color.new(color.navy, 15))

    table.cell(t, 0, 1, "EMA Trend", text_color=color.white)
    table.cell(t, 1, 1, trend_up ? "UP" : trend_down ? "DOWN" : "FLAT", text_color=trend_up ? color.lime : trend_down ? color.red : color.gray)

    table.cell(t, 0, 2, "ADX / DI", text_color=color.white)
    table.cell(t, 1, 2, str.tostring(math.round(adx_val, 1)) + " | +" + str.tostring(math.round(plus_di, 1)) + " -" + str.tostring(math.round(minus_di, 1)), text_color=adx_ok and di_buy_ok ? color.lime : color.gray)

    table.cell(t, 0, 3, "Regime L/S", text_color=color.white)
    table.cell(t, 1, 3, str.tostring(regime_score_long) + "/" + str.tostring(regime_score_short) + " (≥" + str.tostring(min_regime_score) + ")", text_color=regime_long_ok ? color.lime : color.red)

    // Entry Quality block
    table.cell(t, 0, 4, "═ Entry Quality v23.4 ═", text_color=color.yellow, bgcolor=color.new(color.black, 60))
    table.cell(t, 1, 4, "Active: " + (use_adx_rising ? "E2 " : "") + (use_htf_candle_confirm ? "E3 " : "") + (use_atr_expansion ? "E4 " : "") + (not use_adx_rising and not use_htf_candle_confirm and not use_atr_expansion ? "NONE" : ""), text_color=color.yellow, bgcolor=color.new(color.black, 60))

    table.cell(t, 0, 5, "[E2] ADX Rising", text_color=color.white)
    eq2_status = use_adx_rising ? (adx_rising ? "PASS ▲" : "BLOCK ─") : "OFF"
    table.cell(t, 1, 5, eq2_status + " (" + str.tostring(math.round(adx_val, 1)) + " vs " + str.tostring(math.round(adx_val[adx_rising_lookback], 1)) + ")", text_color=not use_adx_rising ? color.gray : adx_rising ? color.lime : color.red)

    table.cell(t, 0, 6, "[E3] H4 Candle", text_color=color.white)
    eq3_status = use_htf_candle_confirm ? (h4_bull_candle ? "BULL ▲" : "BEAR ▼") : "OFF"
    table.cell(t, 1, 6, eq3_status + " (C" + str.tostring(math.round(htf_close_prev, 1)) + " O" + str.tostring(math.round(htf_open_prev, 1)) + ")", text_color=not use_htf_candle_confirm ? color.gray : h4_bull_candle ? color.lime : color.red)

    table.cell(t, 0, 7, "[E4] ATR Expansion", text_color=color.white)
    eq4_status = use_atr_expansion ? (atr_expansion_ok ? "PASS ↑" : "BLOCK ↓") : "OFF"
    table.cell(t, 1, 7, eq4_status + " (" + str.tostring(math.round(atr_val, 2)) + " vs avg " + str.tostring(math.round(atr_avg, 2)) + "×" + str.tostring(atr_exp_factor) + ")", text_color=not use_atr_expansion ? color.gray : atr_expansion_ok ? color.lime : color.red)

    table.cell(t, 0, 8, "EQ Score (E2+E3+E4)", text_color=color.white)
    table.cell(t, 1, 8, str.tostring(eq_score_long) + "/3", text_color=eq_score_long >= 2 ? color.lime : eq_score_long == 1 ? color.orange : color.gray)

    table.cell(t, 0, 9, "═ Trade Status ═", text_color=color.aqua, bgcolor=color.new(color.black, 60))
    table.cell(t, 1, 9, "", bgcolor=color.new(color.black, 60))

    table.cell(t, 0, 10, "In Trade / Bars", text_color=color.white)
    table.cell(t, 1, 10, (in_trade ? (in_long ? "LONG" : "SHORT") : "NO") + " / " + str.tostring(bars_in_trade), text_color=in_trade ? color.lime : color.gray)

    table.cell(t, 0, 11, "Current R", text_color=color.white)
    table.cell(t, 1, 11, str.tostring(math.round(current_r, 2)) + "R", text_color=current_r >= 0 ? color.lime : color.red)

    table.cell(t, 0, 12, "Open Profit $", text_color=color.white)
    table.cell(t, 1, 12, str.tostring(math.round(strategy_profit_now, 2)), text_color=strategy_profit_now >= 0 ? color.lime : color.red)

    table.cell(t, 0, 13, "Active Stop", text_color=color.white)
    act_stop = in_long ? nz(best_long_stop) : in_short ? nz(best_short_stop) : na
    table.cell(t, 1, 13, na(act_stop) ? "na" : str.tostring(math.round(act_stop, 2)), text_color=color.orange)

    table.cell(t, 0, 14, "═ Risk Guards ═", text_color=color.aqua, bgcolor=color.new(color.black, 60))
    table.cell(t, 1, 14, "", bgcolor=color.new(color.black, 60))

    table.cell(t, 0, 15, "Daily PnL%", text_color=color.white)
    table.cell(t, 1, 15, str.tostring(math.round(daily_pnl_pct, 2)) + "%", text_color=daily_loss_breached ? color.red : daily_pnl_pct >= 0 ? color.lime : color.orange)

    table.cell(t, 0, 16, "Drawdown%", text_color=color.white)
    table.cell(t, 1, 16, str.tostring(math.round(current_dd_pct, 2)) + "%", text_color=dd_breached ? color.red : color.yellow)

    table.cell(t, 0, 17, "Risk Status", text_color=color.white)
    table.cell(t, 1, 17, daily_loss_breached ? "DAILY-LOSS" : dd_breached ? "DD-BREACH" : in_cooldown ? "COOLDOWN" : no_friday_hold ? "FRI-CLOSE" : "OK", text_color=daily_loss_breached or dd_breached ? color.red : in_cooldown or no_friday_hold ? color.orange : color.lime)

    table.cell(t, 0, 18, "═ System Stats ═", text_color=color.aqua, bgcolor=color.new(color.black, 60))
    table.cell(t, 1, 18, "", bgcolor=color.new(color.black, 60))

    table.cell(t, 0, 19, "Closed Trades", text_color=color.white)
    table.cell(t, 1, 19, str.tostring(strategy.closedtrades) + " | W=" + str.tostring(strategy.wintrades) + " L=" + str.tostring(strategy.losstrades), text_color=strategy.closedtrades >= 30 ? color.lime : color.orange)

    table.cell(t, 0, 20, "Win Rate", text_color=color.white)
    float wr = strategy.closedtrades > 0 ? strategy.wintrades / strategy.closedtrades * 100.0 : na
    table.cell(t, 1, 20, na(wr) ? "N/A" : str.tostring(math.round(wr, 1)) + "%", text_color=na(wr) ? color.gray : wr >= 45 ? color.lime : wr >= 38 ? color.orange : color.red)

    table.cell(t, 0, 21, "Profit Factor", text_color=color.white)
    float pf = math.abs(strategy.grossloss) > 0 ? strategy.grossprofit / math.abs(strategy.grossloss) : na
    table.cell(t, 1, 21, na(pf) ? "N/A" : str.tostring(math.round(pf, 3)), text_color=na(pf) ? color.gray : pf >= 1.7 ? color.lime : pf >= 1.3 ? color.orange : color.red)

    table.cell(t, 0, 22, "Net Profit", text_color=color.white)
    table.cell(t, 1, 22, str.tostring(math.round(strategy.netprofit, 2)) + "$ (" + str.tostring(math.round(strategy.netprofit / strategy.initial_capital * 100.0, 2)) + "%)", text_color=strategy.netprofit >= 0 ? color.lime : color.red)

    table.cell(t, 0, 23, "Entry Config", text_color=color.white)
    table.cell(t, 1, 23, "ADX" + str.tostring(adx_threshold) + " PB" + str.tostring(pullback_atr_mult) + " B" + str.tostring(min_body_atr), text_color=color.white)

    table.cell(t, 0, 24, "Trail", text_color=color.white)
    table.cell(t, 1, 24, use_trailing ? str.tostring(trail_trigger_r) + "R / " + str.tostring(trail_atr_mult) + "×ATR" : "OFF", text_color=use_trailing ? color.lime : color.gray)

    table.cell(t, 0, 25, "CGB Status", text_color=color.white)
    table.cell(t, 1, 25, execute_harness_exit ? ("ON | fired=" + str.tostring(cgb_fired_count)) : "OFF (v23.4 design)", text_color=execute_harness_exit ? color.orange : color.lime)

    table.cell(t, 0, 26, "Symbol / TF", text_color=color.white)
    table.cell(t, 1, 26, syminfo.ticker + " / " + timeframe.period, text_color=color.white)

    table.cell(t, 0, 27, "EMA Dist ATR", text_color=color.white)
    table.cell(t, 1, 27, str.tostring(math.round(ema_distance_atr, 2)), text_color=pullback_ok and extension_ok ? color.lime : color.orange)

    table.cell(t, 0, 28, "Candle Range/Body", text_color=color.white)
    table.cell(t, 1, 28, str.tostring(math.round(signal_range_atr, 2)) + " / " + str.tostring(math.round(body_atr, 3)), text_color=big_candle_ok and min_body_ok ? color.lime : color.orange)

    table.cell(t, 0, 29, "v23.4 vs v23.1", text_color=color.white)
    eq_active = (use_adx_rising ? "E2 " : "") + (use_htf_candle_confirm ? "E3 " : "") + (use_atr_expansion ? "E4 " : "")
    table.cell(t, 1, 29, "CGB: OFF | EQ: " + (eq_active == "" ? "BASE" : eq_active), text_color=color.aqua)

// ============================================================================
// ALERTS
// ============================================================================
if new_long
    alert("CNX v23.4 BUY " + syminfo.ticker + " @ " + str.tostring(close) +
          " | Regime=" + str.tostring(regime_score_long) + "/4" +
          " | ADXRise=" + (adx_rising ? "Y" : "N") +
          " | H4=" + (h4_bull_candle ? "BULL" : "BEAR") +
          " | ATRExp=" + (atr_expansion_ok ? "Y" : "N") +
          " | EQScore=" + str.tostring(eq_score_long) + "/3" +
          " | Qty=" + str.tostring(math.round(trade_qty, 2)),
          alert.freq_once_per_bar_close)

if new_short
    alert("CNX v23.4 SELL " + syminfo.ticker + " @ " + str.tostring(close) +
          " | Regime=" + str.tostring(regime_score_short) + "/4" +
          " | Qty=" + str.tostring(math.round(trade_qty, 2)),
          alert.freq_once_per_bar_close)

if exit_called_this_bar
    alert("CNX v23.4 Exit " + syminfo.ticker + " @ " + str.tostring(close) +
          " | R=" + str.tostring(math.round(current_r, 2)) +
          " | Reason=" + (currency_exit_raw and execute_harness_exit ? "CGB" : daily_loss_breached ? "DAILY-LOSS" : dd_breached ? "DD-BREAK" : no_friday_hold ? "FRIDAY" : "SL/TP/TRAIL"),
          alert.freq_once_per_bar_close)
